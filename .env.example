# Variáveis de ambiente para o FrogBets
# Copie este arquivo para .env e ajuste os valores se necessário.
# O .env já vem com valores padrão para desenvolvimento local.
# Em produção, use valores seguros e nunca commite o .env.

POSTGRES_PASSWORD=frogbets_dev_password
JWT_KEY=frogbets-dev-jwt-key-minimo-32-caracteres-ok
# Em produção, defina a origem real do frontend (ex: https://seudominio.com)
ALLOWED_ORIGINS=http://localhost:3000
# Username do admin master (único que pode promover/revogar outros admins)
MASTER_ADMIN_USERNAME=admin
