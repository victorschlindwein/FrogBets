# Variáveis de ambiente para o FrogBets API
# Copie este arquivo para .env e preencha os valores reais.
# Em produção, configure essas variáveis diretamente no servidor ou na pipeline de CI/CD.
#
# O ASP.NET Core lê variáveis de ambiente usando __ como separador de hierarquia.
# Exemplo: ConnectionStrings__DefaultConnection sobrescreve ConnectionStrings.DefaultConnection

ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=FrogBets;Username=postgres;Password=SUA_SENHA_AQUI

# Chave JWT — mínimo 32 caracteres, use um valor aleatório seguro
# Gere um com: openssl rand -base64 32
Jwt__Key=GERE_UMA_CHAVE_SEGURA_AQUI
Jwt__Issuer=FrogBets
Jwt__Audience=FrogBets
Jwt__ExpirationMinutes=60
