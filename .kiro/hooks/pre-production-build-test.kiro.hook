{
  "enabled": true,
  "name": "Pre-Production Build & Test",
  "description": "Roda o build Docker completo (API + frontend) e todos os testes (dotnet test + vitest + Cypress E2E) antes de lançar em produção. Disparar manualmente antes de qualquer deploy.",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "runCommand",
    "command": "docker build -f Dockerfile.api -t frogbets-api:pre-release . && docker build -f Dockerfile.frontend -t frogbets-frontend:pre-release . && dotnet test --configuration Release --verbosity quiet && cd frontend && npm run test && npm run test:e2e",
    "timeout": 300
  }
}